<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F0F0F0">

    <TextView
        android:id="@+id/tvHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom|end"
        android:text=""
        android:textColor="#888888"
        android:textSize="18sp"
        android:padding="8dp"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"/>

    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:gravity="end|bottom"
        android:padding="16dp"
        android:text=""
        android:textSize="48sp"
        android:textColor="#000000" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginBottom="16dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5">

        <Button android:text="C" android:id="@+id/btnAC" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
        <Button android:text="DEL" android:id="@+id/btnDel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
        <Button android:text="/" android:id="@+id/btnDivide" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
        <Button android:text="*" android:id="@+id/btnMultiply" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />

        <Button android:text="7" android:onClick="onDigitClick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
        <Button android:text="8" android:onClick="onDigitClick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
        <Button android:text="9" android:onClick="onDigitClick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
        <Button android:text="-" android:id="@+id/btnMinus" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />

        <Button android:text="4" android:onClick="onDigitClick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
        <Button android:text="5" android:onClick="onDigitClick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
        <Button android:text="6" android:onClick="onDigitClick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
        <Button android:text="+" android:id="@+id/btnPlus" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />

        <Button android:text="1" android:onClick="onDigitClick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
        <Button android:text="2" android:onClick="onDigitClick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
        <Button android:text="3" android:onClick="onDigitClick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
        <Button android:text="=" android:id="@+id/btnEquals" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_rowSpan="2" android:layout_height="match_parent"/>

        <Button android:text="0" android:onClick="onDigitClick" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="3" android:layout_columnSpan="3"/>

    </GridLayout>
</LinearLayout>